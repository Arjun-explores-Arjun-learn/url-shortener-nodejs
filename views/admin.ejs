<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Admin Dashboard</title>

  <style>
    /*DARK ADMIN THEME */
    body {
      margin: 0;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-color: #0f172a;
      color: #e2e8f0;
    }

    /*HEADER */
    .header {
      background-color: #020617;
      padding: 20px;
      font-size: 22px;
      font-weight: bold;
      border-bottom: 1px solid #1e293b;
    }

    .container {
      padding: 30px;
    }

    h2 {
      margin-bottom: 15px;
    }

    /*FORM */
    input {
      padding: 10px;
      margin: 8px 0;
      width: 300px;
      border: none;
      border-radius: 5px;
      background-color: #1e293b;
      color: white;
    }

    button {
      padding: 10px 15px;
      background-color: #3b82f6;
      border: none;
      border-radius: 5px;
      color: white;
      cursor: pointer;
    }

    button:hover {
      background-color: #2563eb;
    }

    /*GENERATED URL BOX */
    .url-box {
      margin-top: 20px;
      padding: 15px;
      background: #1e293b;
      border: 1px solid #334155;
      display: inline-block;
      border-radius: 5px;
    }

    a {
      color: #38bdf8;
      text-decoration: none;
    }

    /*TABLE */
    table {
      margin-top: 30px;
      border-collapse: collapse;
      width: 100%;
    }

    th, td {
      padding: 12px;
      text-align: center;
      border-bottom: 1px solid #334155;
    }

    th {
      background-color: #1e293b;
      color: #f8fafc;
    }

    tr:hover {
      background-color: #1e293b;
    }

    .badge {
      color: #38bdf8;
      font-size: 14px;
      margin-left: 10px;
    }
  </style>
</head>

<body>

  <!--ADMIN HEADER -->
  <div class="header">
    🔐 Admin Dashboard <span class="badge">(Admin)</span>
  </div>

  <div class="container">

    <h2>Create Short URL</h2>

    <!--SHOW GENERATED URL -->
    <% if (locals.id) { %>
      <div class="url-box">
        <p>
          Generated URL:
          <a href="http://localhost:7001/<%= id %>" target="_blank">
            http://localhost:7001/<%= id %>
          </a>
        </p>
        <button onclick="copyToClipboard()">Copy</button>
      </div>
    <% } %>

    <!--FORM -->
    <form method="POST" action="/url">
      <div>
        <label>Original URL</label><br/>
        <input 
          type="text" 
          name="url" 
          placeholder="https://example.com" 
          required 
        />
      </div>

      <div>
        <label>Custom Alias</label><br/>
        <input 
          type="text" 
          name="customAlias" 
          placeholder="e.g. admin-link"
        />
      </div>

      <div>
        <label>Expiry (minutes)</label><br/>
        <input 
          type="number" 
          name="expiresIn" 
          placeholder="e.g. 60"
        />
      </div>

      <button type="submit">Generate</button>
    </form>

    <!--URL TABLE -->
    <% if (locals.urls) { %>
      <table>
        <thead>
          <tr>
            <th>S.NO</th>
            <th>Short URL</th>
            <th>Original URL</th>
            <th>Clicks</th>
          </tr>
        </thead>

        <tbody>
          <% urls.forEach((url, index) => { %>
            <tr>
              <td><%= index + 1 %></td>

              <td>
                <a href="http://localhost:7001/<%= url.shortId %>" target="_blank">
                  <%= url.shortId %>
                </a>
              </td>

              <td><%= url.redirectURL %></td>

              <td><%= url.visitHistory.length %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

  </div>

  <!--COPY SCRIPT -->
  <script>
    function copyToClipboard() {
      const text = "http://localhost:7001/<%= locals.id %>";
      navigator.clipboard.writeText(text)
        .then(() => alert("Copied!"))
        .catch(() => alert("Failed to copy"));
    }
  </script>

</body>
</html>